ANTHROPIC_API_KEY=your_key_here
AZURE_DEVOPS_ORG=your_org
AZURE_DEVOPS_PROJECT=your_project
AZURE_DEVOPS_PAT=your_pat
PORT=3001

# Sandbox mode for executing AI-generated tests:
#   docker  - run inside the official Playwright container (isolated, no secrets)
#   process - hardened child_process (stripped env, no shell)
#   (unset) - auto: docker if the daemon is reachable, else process
VERIFLOW_SANDBOX=
# Docker container network for the sandbox (default: none). Set to "bridge" when
# the target site is on the public internet.
VERIFLOW_DOCKER_NETWORK=
